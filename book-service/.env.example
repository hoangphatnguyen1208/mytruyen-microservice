# ===========================================
# MyTruyen Backend - Environment Variables
# ===========================================
# Copy this file to .env and update with your values
# Command: cp .env.example .env

# ===========================================
# DATABASE CONFIGURATION
# ===========================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=mytruyen
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_EXTERNAL_PORT=5433

# Database URL (auto-generated from above values)
# Format: postgresql+asyncpg://user:password@host:port/database
# DATABASE_URL=postgresql+asyncpg://postgres:your_password@localhost:5432/mytruyen

# ===========================================
# REDIS CONFIGURATION
# ===========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here
# REDIS_DB=0
# REDIS_URL=redis://:your_redis_password@localhost:6379/0

# ===========================================
# JWT & SECURITY
# ===========================================
# Generate a secure random key with: openssl rand -hex 32
SECRET_KEY=your_super_secret_key_at_least_32_characters_long_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ===========================================
# PINECONE VECTOR DATABASE
# ===========================================
# Get API key from: https://www.pinecone.io/
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_ENVIRONMENT=us-east-1-aws
PINECONE_INDEX_NAME=hybrid-spilt

# ===========================================
# APPLICATION SETTINGS
# ===========================================
PROJECT_NAME=MyTruyen API
ENVIRONMENT=development
# ENVIRONMENT=production
# ENVIRONMENT=staging

# API Configuration
API_VERSION=v1
DEBUG=true
# DEBUG=false

# Server Configuration
HOST=0.0.0.0
PORT=8000

# CORS Settings (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
# CORS_ORIGINS=*

# ===========================================
# LOGGING
# ===========================================
LOG_LEVEL=INFO
# LOG_LEVEL=DEBUG
# LOG_LEVEL=WARNING
# LOG_LEVEL=ERROR

# ===========================================
# FILE UPLOAD
# ===========================================
MAX_UPLOAD_SIZE=10485760  # 10MB in bytes
UPLOAD_DIR=./uploads
ALLOWED_AUDIO_EXTENSIONS=.mp3,.wav,.m4a,.ogg,.flac,.webm,.mp4

# ===========================================
# AI/ML MODELS
# ===========================================
# BGE-M3 Model
BGE_MODEL_NAME=BAAI/bge-m3
BGE_USE_FP16=true
BGE_DEVICE=cuda
# BGE_DEVICE=cpu

# Faster Whisper (Speech-to-Text)
WHISPER_MODEL=turbo
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
# WHISPER_DEVICE=cuda

# ===========================================
# BACKGROUND JOBS (ARQ)
# ===========================================
ARQ_REDIS_HOST=localhost
ARQ_REDIS_PORT=6379
ARQ_REDIS_PASSWORD=your_redis_password_here
ARQ_QUEUE_NAME=mytruyen:queue

# ===========================================
# PAGINATION
# ===========================================
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# ===========================================
# RATE LIMITING
# ===========================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60

# ===========================================
# EXTERNAL SERVICES
# ===========================================
# YouTube Download (yt-dlp)
YOUTUBE_DOWNLOAD_DIR=./temp/youtube
YOUTUBE_MAX_DURATION=600  # seconds

# Email (if needed)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=noreply@mytruyen.com

# ===========================================
# TESTING
# ===========================================
TEST_DATABASE_URL=postgresql+asyncpg://postgres:test_password@localhost:5432/mytruyen_test
TEST_REDIS_URL=redis://:test_password@localhost:6379/1

# ===========================================
# DOCKER COMPOSE OVERRIDE
# ===========================================
# These are used by docker-compose.yml
COMPOSE_PROJECT_NAME=mytruyen
